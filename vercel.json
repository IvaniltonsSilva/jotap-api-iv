    <script>
    function animateOdd() {
        const display = document.getElementById('multiplier');
        const oddX = document.querySelector('.odd-x');
        let current = 1.00;
        const target = 100.00;
        const duration = 4000; // 4 segundos para subir
        const startTime = performance.now();

        function update(currentTime) {
            const elapsed = currentTime - startTime;
            const progress = Math.min(elapsed / duration, 1);
            
            // Suavização da subida
            const easeOut = 1 - Math.pow(1 - progress, 3);
            current = 1 + (target - 1) * easeOut;

            display.innerText = current.toFixed(2);

            // Transição para o verde no final
            if (current >= 98) {
                display.style.color = "#00ff88"; // Verde Green
                display.style.textShadow = "0 0 15px rgba(0, 255, 136, 0.6)";
                oddX.style.color = "#00ff88";
            }

            if (progress < 1) {
                requestAnimationFrame(update);
            } else {
                display.innerText = "100.00";
            }
        }
        requestAnimationFrame(update);
    }

    window.onload = animateOdd;

